# Blockchain Configuration
PRIVATE_KEY=your_private_key_here
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# API Keys for verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key

# Backend Configuration
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/enobridge
REDIS_URL=redis://localhost:6379
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=your_influxdb_token
INFLUXDB_ORG=enobridge
INFLUXDB_BUCKET=metrics

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# AI Service
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=your_ai_service_api_key

# Relayer Configuration
RELAYER_PRIVATE_KEY=your_relayer_private_key
RELAYER_ADDRESS=0x...

# Contract Addresses (Amoy)
AMOY_BRIDGE_ADDRESS=0x...
AMOY_FORWARDER_ADDRESS=0x...
AMOY_TOKEN_ADDRESS=0x...

# Contract Addresses (Sepolia)
SEPOLIA_BRIDGE_ADDRESS=0x...
SEPOLIA_FORWARDER_ADDRESS=0x...
SEPOLIA_WRAPPED_TOKEN_ADDRESS=0x...

# Monitoring
ENABLE_PROMETHEUS=true
PROMETHEUS_PORT=9090

# WebSocket
WS_PORT=3001

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
